# Devin API (service user with ManageOrgSessions permission)
DEVIN_API_KEY=cog_your_key_here
DEVIN_ORG_ID=org-your_org_id

# GitHub
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_TOKEN=ghp_your_pat_here
GITHUB_REPO=your-user/superset

# Optional: cap ACU spend per session (demo safety)
MAX_ACU_LIMIT=10

# Poller interval in seconds
POLL_INTERVAL_SEC=30

# Label that triggers remediation
TRIGGER_LABEL=devin-autofix

# Set to true to skip real Devin API calls (local UI testing only)
DRY_RUN=false
